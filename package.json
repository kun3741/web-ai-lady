{
  "name": "virtual-lady-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Private NestJS + MongoDB + Redis/BullMQ Telegram copilot assistant",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api && nest build workers",
    "build:api": "nest build api",
    "build:workers": "nest build workers",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:workers\"",
    "dev:api": "nest start api --watch",
    "dev:workers": "nest start workers --watch",
    "start": "node dist/apps/api/main.js",
    "start:workers": "node dist/apps/workers/main.js",
    "lint": "eslint \"{src,apps}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,apps}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "seed": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto-js": "^4.2.0",
    "grammy": "^1.30.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.0",
    "mongoose": "^8.5.0",
    "nestjs-pino": "^4.1.0",
    "openai": "^4.55.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "telegram": "^2.26.22",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
